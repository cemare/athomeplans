// Prisma schema for Athena Interior Design Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// SQLite does not support native enums — using String fields with validation at app level

model DesignPlan {
  id          String  @id @default(cuid())
  title       String
  slug        String  @unique
  description String
  category    String  // PlanCategory: LIVING_ROOM | BEDROOM | KITCHEN | BATHROOM | DINING_ROOM | HOME_OFFICE | FULL_HOME
  style       String  // PlanStyle: MODERN | CONTEMPORARY | TRADITIONAL | MINIMALIST | BOHEMIAN | SCANDINAVIAN | INDUSTRIAL | COASTAL
  roomSizeSqFt Int?
  estimatedBudgetUsd Int?  // in cents
  coverImageUrl String?
  images      String  @default("[]") // JSON array of image URLs
  featured    Boolean      @default(false)
  published   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  furnitureItems FurnitureItem[]
  tags           Tag[]           @relation("PlanTags")
  savedPlans     SavedPlan[]
}

model FurnitureItem {
  id          String @id @default(cuid())
  name        String
  description String?
  category    String
  estimatedPriceUsd Int? // in cents
  imageUrl    String?
  affiliateUrl String?

  plans       DesignPlan[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  plans DesignPlan[] @relation("PlanTags")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  sessions     UserSession[]
  savedPlans   SavedPlan[]
}

model UserSession {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SavedPlan {
  id             String     @id @default(cuid())
  title          String
  notes          String?
  roomType       String?
  style          String?
  palette        String?
  layoutJson     String     @default("{}")
  shareToken     String     @unique @default(cuid())
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourcePlanId   String?
  sourcePlan     DesignPlan? @relation(fields: [sourcePlanId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}
