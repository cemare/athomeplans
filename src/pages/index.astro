---
import BaseLayout from "../layouts/BaseLayout.astro";
import EmailCapture from "../components/EmailCapture.astro";
import { getAllPosts } from "../lib/blog";
import { getAllPlans } from "../lib/plans";

const latestPosts = getAllPosts().slice(0, 3);
const featuredPlans = getAllPlans().filter((plan) => plan.featured).slice(0, 3);

const formatShortDate = (dateValue: string): string =>
  new Date(dateValue).toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  });
---

<BaseLayout>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">At Home Plans</p>
      <h1>Interior Design, Made Accessible</h1>
      <p>
        Curated room plans, styling guides, and shopping lists — everything you need to design
        a space you love.
      </p>
      <div class="heroCtas">
        <a href="/plans" class="btnPrimary">Browse Plans</a>
        <a href="/blog" class="btnSecondary">Read the Journal</a>
        <a href="/shop" class="btnSecondary">Shop</a>
      </div>
    </div>
  </section>

  <hr class="sectionDivider" />

  <section class="container sectionPad">
    <div class="sectionHead">
      <h2>Featured Plans</h2>
      <p>Proven room layouts with curated shopping guidance — ready to make your own.</p>
    </div>
    <div class="postGrid">
      {featuredPlans.map((plan) => (
        <article class="postCard">
          <p class="metaLine">{plan.category} · {plan.style}</p>
          <h3><a href={`/plans/${plan.slug}`}>{plan.title}</a></h3>
          <p>{plan.summary}</p>
          <a href={`/plans/${plan.slug}`} class="readMoreLink">View plan</a>
        </article>
      ))}
    </div>
  </section>

  <hr class="sectionDivider" />

  <section class="shopCta">
    <div class="container shopCtaInner">
      <div>
        <p class="eyebrow">Digital Templates</p>
        <h2>Shop Our Design Templates</h2>
        <p>Instant download floor plans, mood boards &amp; design templates — starting at $15. Print or use digitally to bring your vision to life.</p>
        <div class="heroCtas">
          <a href="https://www.etsy.com/shop/AtHomePlans" class="btnPrimary" target="_blank" rel="noreferrer">Browse Templates on Etsy</a>
          <a href="/shop" class="btnSecondary">See All Resources</a>
        </div>
      </div>
      <div class="shopCtaBadge" aria-hidden="true">
        <span class="shopCtaIcon">⬡</span>
        <p>Instant<br />Download</p>
      </div>
    </div>
  </section>

  <hr class="sectionDivider" />

  <section class="ebooksBanner">
    <div class="container ebooksBannerInner">
      <div class="ebooksBannerText">
        <p class="eyebrow">New — Instant Download</p>
        <h2>Interior Design E-Books</h2>
        <p>Three practical guides covering small living rooms, furniture buying, and decorating on a budget. Download instantly and start designing today.</p>
        <div class="heroCtas">
          <a href="/ebooks" class="btnPrimary">Browse E-Books</a>
        </div>
      </div>
      <div class="ebooksBannerCards" aria-hidden="true">
        <div class="ebookMiniCard">
          <span>🛋️</span>
          <p>Style a Small<br />Living Room</p>
          <strong>$14.99</strong>
        </div>
        <div class="ebookMiniCard ebookMiniCardRaised">
          <span>🪑</span>
          <p>Complete Furniture<br />Buying Guide</p>
          <strong>$19.99</strong>
        </div>
        <div class="ebookMiniCard">
          <span>🏠</span>
          <p>Design on a<br />Budget</p>
          <strong>$24.99</strong>
        </div>
      </div>
    </div>
  </section>

  <hr class="sectionDivider" />

  <section class="container sectionPad">
    <div class="latestWrap">
      <div>
        <div class="sectionHead">
          <h2>From the Journal</h2>
          <p>Practical styling tips, room ideas, and design inspiration.</p>
        </div>
        <div class="postGrid">
          {latestPosts.map((post) => (
            <article class="postCard">
              <p class="metaLine">{formatShortDate(post.publishedAt)}</p>
              <h3><a href={`/blog/${post.slug}`}>{post.title}</a></h3>
              <p>{post.excerpt}</p>
              <a href={`/blog/${post.slug}`} class="readMoreLink">Read article</a>
            </article>
          ))}
        </div>
      </div>
      <div>
        <EmailCapture />
      </div>
    </div>
  </section>
</BaseLayout>
