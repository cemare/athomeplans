---
import BaseLayout from "../layouts/BaseLayout.astro";
import EmailCapture from "../components/EmailCapture.astro";
import { getAllPosts } from "../lib/blog";

const latestPosts = getAllPosts().slice(0, 3);

const formatShortDate = (dateValue: string): string =>
  new Date(dateValue).toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  });
---

<BaseLayout>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">At Home Plans</p>
      <h1>Interior Design, Made Accessible</h1>
      <p>
        Curated room plans, styling guides, and shopping lists — everything you need to design
        a space you love.
      </p>
      <div class="heroCtas">
        <a href="/blog" class="btnPrimary">Read the Journal</a>
        <a href="/shop" class="btnSecondary">Shop</a>
      </div>
    </div>
  </section>

  <hr class="sectionDivider" />

  <section class="container sectionPad">
    <div class="sectionHead">
      <h2>Everything We Offer</h2>
      <p>Explore our content, resources, and products — all in one place.</p>
    </div>
    <div class="postGrid">
      <article class="postCard">
        <p class="metaLine">Content</p>
        <h3><a href="/blog">The Journal</a></h3>
        <p>Practical styling tips, room ideas, and design inspiration. New articles published regularly to help you make the most of any space.</p>
        <a href="/blog" class="readMoreLink">Browse articles</a>
      </article>
      <article class="postCard">
        <p class="metaLine">Products</p>
        <h3><a href="/shop">Shop</a></h3>
        <p>Floor plans, mood boards, and design templates — available as instant downloads from our Etsy storefront, starting at $15.</p>
        <a href="/shop" class="readMoreLink">Visit the shop</a>
      </article>
    </div>
  </section>

  <hr class="sectionDivider" />

  <section class="shopCta">
    <div class="container shopCtaInner">
      <div>
        <p class="eyebrow">Digital Templates</p>
        <h2>Shop Our Design Templates</h2>
        <p>Instant download floor plans, mood boards &amp; design templates — starting at $15. Print or use digitally to bring your vision to life.</p>
        <div class="heroCtas">
          <a href="https://www.etsy.com/shop/AtHomePlans" class="btnPrimary" target="_blank" rel="noreferrer">Browse Templates on Etsy</a>
          <a href="/shop" class="btnSecondary">See All Resources</a>
        </div>
      </div>
      <div class="shopCtaBadge" aria-hidden="true">
        <span class="shopCtaIcon">⬡</span>
        <p>Instant<br />Download</p>
      </div>
    </div>
  </section>

  <hr class="sectionDivider" />

  <section class="container sectionPad">
    <div class="latestWrap">
      <div>
        <div class="sectionHead">
          <h2>From the Journal</h2>
          <p>Practical styling tips, room ideas, and design inspiration.</p>
        </div>
        <div class="postGrid">
          {latestPosts.map((post) => (
            <article class="postCard">
              <p class="metaLine">{formatShortDate(post.publishedAt)}</p>
              <h3><a href={`/blog/${post.slug}`}>{post.title}</a></h3>
              <p>{post.excerpt}</p>
              <a href={`/blog/${post.slug}`} class="readMoreLink">Read article</a>
            </article>
          ))}
        </div>
      </div>
      <div>
        <EmailCapture />
      </div>
    </div>
  </section>
</BaseLayout>
