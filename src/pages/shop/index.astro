---

<BaseLayout
  title="Shop"
  description="Browse At Home Plans design packages — downloadable room plans, layout guides, and decor checklists for every budget."
  canonicalPath="/shop"
>
  <section class="shopHero container">
    <p class="eyebrow">At Home Plans</p>
    <h1>The Shop</h1>
    <p class="shopSubtitle">
      Downloadable design packages to help you transform any room — at any budget.
    </p>
  </section>

  <section class="container shopGrid sectionPad">
    {products.map((product) => <ProductCard product={product} />)}
  </section>

  <section class="shopEtsyNote container">
    <p>
      All purchases are fulfilled through our
      <a href="https://www.etsy.com/shop/athomeplans" target="_blank" rel="noreferrer">Etsy storefront</a>.
      Digital files are delivered instantly after checkout.
    </p>
  </section>
</BaseLayout>

<style>
  .shopHero {
    padding: 5rem 0 3rem;
    border-bottom: 1px solid var(--border);
  }

  .shopHero h1 {
    font-family: var(--font-sans);
    font-size: clamp(2.4rem, 4vw, 4rem);
    font-weight: 300;
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .shopSubtitle {
    color: var(--muted);
    font-size: 1.05rem;
    max-width: 52ch;
    margin: 0;
    line-height: 1.7;
  }

  .shopGrid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.75rem;
    align-items: start;
  }

  .shopEtsyNote {
    padding-bottom: 4rem;
    border-top: 1px solid var(--border);
    padding-top: 1.5rem;
  }

  .shopEtsyNote p {
    color: var(--muted);
    font-size: 0.88rem;
    margin: 0;
  }

  .shopEtsyNote a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  @media (max-width: 1040px) {
    .shopGrid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .shopHero {
      padding: 3.5rem 0 2.5rem;
    }

    .shopGrid {
      grid-template-columns: 1fr;
    }
  }
</style>
