---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductCard from "../../components/ProductCard.astro";
import type { Product } from "../../components/ProductCard.astro";

const products: Product[] = [
  {
    id: "living-room-mood-board",
    title: "Living Room Mood Board with Shopping Links",
    category: "Living Room",
    style: "Scandinavian · Japandi",
    price: 27,
    description:
      "A full mood board PDF with furniture, textiles, and accessories curated around a Scandinavian-Japandi aesthetic. Includes clickable shopping links for every item, a color and material guide, and layout suggestions — delivered as an instant download.",
    images: [
      { src: "/images/etsy-living-room-mood-board.png", alt: "Living Room Mood Board with Shopping Links" },
    ],
    etsy_url: "https://www.etsy.com/shop/athomeplans",
  },
  {
    id: "room-layout-plan",
    title: "Room Layout Plan",
    category: "Layout & Planning",
    style: "Universal",
    price: 19,
    description:
      "A furniture placement guide and room layout diagram to help you arrange any space with confidence. Includes scaled floor plan templates, traffic flow principles, and a quick-reference measurement guide for sofas, rugs, and lighting.",
    images: [
      { src: "/images/etsy-room-layout-plan.png", alt: "Room Layout Plan" },
    ],
    etsy_url: "https://www.etsy.com/shop/athomeplans",
  },
  {
    id: "home-decor-style-guide",
    title: "Home Decor Style Guide",
    category: "Style Guide",
    style: "Multi-Room",
    price: 22,
    description:
      "A comprehensive digital style guide covering color palettes, material pairings, and decor principles for every room in your home. Includes a clickable shopping list and practical tips for mixing budget and premium pieces with a cohesive result.",
    images: [
      { src: "/images/etsy-home-decor-style-guide.png", alt: "Home Decor Style Guide" },
    ],
    etsy_url: "https://www.etsy.com/shop/athomeplans",
  },
  {
    id: "japandi-living-room-package",
    title: "Pre-Designed Living Room Package (Japandi)",
    category: "Living Room",
    style: "Japandi",
    price: 47,
    description:
      "A complete, ready-to-implement Japandi living room design. Includes a curated mood board, furniture placement map, clickable shopping list with warm neutrals and natural materials, and a palette guide — everything to achieve that calm, intentional look.",
    images: [
      { src: "/images/etsy-japandi-living-room.png", alt: "Pre-Designed Living Room Package (Japandi)" },
    ],
    etsy_url: "https://www.etsy.com/shop/athomeplans",
  },
  {
    id: "bedroom-mood-board",
    title: "Bedroom Interior Design Mood Board",
    category: "Bedroom",
    style: "Minimalist · Biophilic",
    price: 27,
    description:
      "A calming Japandi-inspired bedroom mood board with clickable shopping links for every piece. Covers platform bed styling, integrated storage, muted whites and greys, and natural biophilic accents — delivered as an instant PDF download.",
    images: [
      { src: "/images/etsy-bedroom-mood-board.png", alt: "Bedroom Interior Design Mood Board" },
    ],
    etsy_url: "https://www.etsy.com/shop/athomeplans",
  },
];
---

<BaseLayout
  title="Shop"
  description="Browse At Home Plans design packages — downloadable room plans, layout guides, and decor checklists for every budget."
  canonicalPath="/shop"
>
  <section class="shopHero container">
    <p class="eyebrow">At Home Plans</p>
    <h1>The Shop</h1>
    <p class="shopSubtitle">
      Downloadable design packages to help you transform any room — at any budget.
    </p>
  </section>

  <section class="container shopGrid sectionPad">
    {products.map((product) => <ProductCard product={product} />)}
  </section>

  <section class="shopEtsyNote container">
    <p>
      All purchases are fulfilled through our
      <a href="https://www.etsy.com/shop/athomeplans" target="_blank" rel="noreferrer">Etsy storefront</a>.
      Digital files are delivered instantly after checkout.
    </p>
  </section>
</BaseLayout>

<style>
  .shopHero {
    padding: 5rem 0 3rem;
    border-bottom: 1px solid var(--border);
  }

  .shopHero h1 {
    font-family: var(--font-sans);
    font-size: clamp(2.4rem, 4vw, 4rem);
    font-weight: 300;
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .shopSubtitle {
    color: var(--muted);
    font-size: 1.05rem;
    max-width: 52ch;
    margin: 0;
    line-height: 1.7;
  }

  .shopGrid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.75rem;
    align-items: start;
  }

  .shopEtsyNote {
    padding-bottom: 4rem;
    border-top: 1px solid var(--border);
    padding-top: 1.5rem;
  }

  .shopEtsyNote p {
    color: var(--muted);
    font-size: 0.88rem;
    margin: 0;
  }

  .shopEtsyNote a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  @media (max-width: 1040px) {
    .shopGrid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .shopHero {
      padding: 3.5rem 0 2.5rem;
    }

    .shopGrid {
      grid-template-columns: 1fr;
    }
  }
</style>
