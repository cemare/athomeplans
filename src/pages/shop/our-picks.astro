  description: string;
  priceRange: string;
  image: string;
  imageAlt: string;
  url: string;
  retailer: string;
};

type RoomCategory = {
  id: string;
  label: string;
  products: AffiliateProduct[];
};

const categories: RoomCategory[] = [
