---

<BaseLayout
  title="Shop Our Picks"
  description="Curated home decor and furniture picks from At Home Plans — organized by room category to make shopping your space easier."
  canonicalPath="/shop/our-picks"
>
  <div class="affiliateBar container">
    <p>
      <strong>Affiliate disclosure:</strong> This page contains affiliate links. We may earn a small
      commission if you buy through our links, at no extra cost to you.
      <a href="/affiliate-disclosure">Learn more</a>.
    </p>
  </div>

  <section class="picksHero container">
    <p class="eyebrow">At Home Plans</p>
    <h1>Shop Our Picks</h1>
    <p class="picksSubtitle">
      Curated furniture and decor we actually recommend — organized by room so you can shop with purpose.
    </p>
  </section>

  <nav class="categoryNav container" aria-label="Room categories">
    {categories.map((cat) => (
      <a href={`#${cat.id}`}>{cat.label}</a>
    ))}
  </nav>

  {categories.map((category) => (
    <section id={category.id} class="categorySection container sectionPad">
      <h2 class="categoryHeading">{category.label}</h2>
      <div class="picksGrid">
        {category.products.map((product) => (
          <article class="pickCard">
            <div class="pickImageWrap">
              <img src={product.image} alt={product.imageAlt} loading="lazy" />
            </div>
            <div class="pickBody">
              <p class="pickRetailer">{product.retailer}</p>
              <h3 class="pickName">{product.name}</h3>
              <p class="pickDescription">{product.description}</p>
              <p class="pickPrice">{product.priceRange}</p>
              <a
                href={product.url}
                target="_blank"
                rel="sponsored nofollow noopener"
                class="pickCta"
              >
                Shop on {product.retailer} →
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>
  ))}
</BaseLayout>

<style>
  .affiliateBar {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 0.7rem 0;
  }

  .affiliateBar p {
    font-size: 0.82rem;
    color: var(--muted);
    margin: 0;
    text-align: center;
  }

  .affiliateBar strong {
    color: var(--text);
    font-weight: 600;
  }

  .affiliateBar a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .picksHero {
    padding: 4rem 0 2.5rem;
    border-bottom: 1px solid var(--border);
  }

  .picksHero h1 {
    font-family: var(--font-sans);
    font-size: clamp(2.2rem, 4vw, 3.8rem);
    font-weight: 300;
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .picksSubtitle {
    color: var(--muted);
    font-size: 1.05rem;
    max-width: 52ch;
    margin: 0;
    line-height: 1.7;
  }

  .categoryNav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border);
  }

  .categoryNav a {
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 0.4rem 0.9rem;
    border-radius: 99px;
    transition: color 0.15s, border-color 0.15s;
    text-decoration: none;
  }

  .categoryNav a:hover {
    color: var(--text);
    border-color: var(--text);
  }

  .categorySection {
    border-bottom: 1px solid var(--border);
  }

  .categoryHeading {
    font-family: var(--font-sans);
    font-size: 1.4rem;
    font-weight: 300;
    letter-spacing: -0.01em;
    margin: 0 0 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .picksGrid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.75rem;
    align-items: start;
  }

  .pickCard {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .pickImageWrap {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--surface);
  }

  .pickImageWrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .pickCard:hover .pickImageWrap img {
    transform: scale(1.03);
  }

  .pickBody {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .pickRetailer {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--subtle);
    margin: 0 0 0.4rem;
  }

  .pickName {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 500;
    margin: 0 0 0.6rem;
    letter-spacing: -0.01em;
  }

  .pickDescription {
    font-size: 0.88rem;
    color: var(--muted);
    line-height: 1.6;
    margin: 0 0 1rem;
    flex: 1;
  }

  .pickPrice {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text);
    margin: 0 0 1rem;
  }

  .pickCta {
    display: inline-block;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    border: 1px solid var(--accent);
    padding: 0.45rem 0.85rem;
    border-radius: 3px;
    transition: background 0.15s, color 0.15s;
    align-self: flex-start;
  }

  .pickCta:hover {
    background: var(--accent);
    color: #fff;
  }

  @media (max-width: 1040px) {
    .picksGrid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .picksHero {
      padding: 3rem 0 2rem;
    }

    .picksGrid {
      grid-template-columns: 1fr;
    }
  }
</style>
