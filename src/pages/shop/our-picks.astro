        retailer: "Wayfair",
      },
    ],
  },
  {
    id: "kitchen",
    label: "Kitchen",
    products: [
      {
        name: "Open Shelving Brackets",
        description:
          "Heavy-duty steel floating shelf brackets with a matte black finish. Rated for substantial weight and compatible with standard lumber shelving.",
        priceRange: "$30–$80",
        image: "/images/cover-how-to-plan-a-living-room-layout.jpg",
        imageAlt: "Matte black floating shelf brackets mounted in kitchen",
        url: "https://www.amazon.com/s?k=floating+shelf+brackets",
        retailer: "Amazon",
      },
      {
        name: "Woven Pendant Light",
