---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllPlans } from "../../lib/plans";

export function getStaticPaths() {
  return getAllPlans().map((plan) => ({
    params: { slug: plan.slug },
    props: { plan },
  }));
}

const { plan } = Astro.props;

if (!plan) {
  throw new Error("Plan not found for route");
}

const formatBudget = (amount: number): string =>
  new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: "USD",
    maximumFractionDigits: 0,
  }).format(amount);
---

<BaseLayout
  title={plan.title}
  description={plan.summary}
  canonicalPath={`/plans/${plan.slug}`}
  ogImage={plan.coverImage || "/images/og-default.svg"}
>
  <section class="container sectionPad">
    <article class="postDetail">
      <p class="metaLine"><a href="/plans">← Back to plans</a></p>
      <h1>{plan.title}</h1>
      <p class="lead">
        {plan.category} · {plan.style}
        {plan.roomSizeSqFt ? ` · ${plan.roomSizeSqFt} sq ft` : ""}
      </p>
      {plan.coverImage ? (
        <div class="coverMedia detailCoverMedia">
          <img src={plan.coverImage} alt={plan.title} loading="eager" />
        </div>
      ) : null}
      <p>{plan.summary}</p>
      <p>
        Estimated budget: <strong>{formatBudget(plan.estimatedBudgetUsd)}</strong>
      </p>

      <div class="articleBody">
        {plan.details.map((detail) => (
          <p>{detail}</p>
        ))}
      </div>

      {plan.shoppingLinks?.length ? (
        <div class="sidebarBlock">
          <h2>Shopping Links</h2>
          <ul>
            {plan.shoppingLinks.map((link) => (
              <li>
                <a href={link.url} target="_blank" rel="noreferrer">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ) : null}
    </article>
  </section>
</BaseLayout>
