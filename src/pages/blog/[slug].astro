---
import { marked } from "marked";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PinterestSlider from "../../components/PinterestSlider.astro";
import { getAllPosts } from "../../lib/blog";

export function getStaticPaths() {
  return getAllPosts().map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

if (!post) {
  throw new Error("Blog post not found for route");
}

const siteUrl = import.meta.env.PUBLIC_SITE_URL || "https://athomeplans.com";
const postUrl = `${siteUrl}/blog/${post.slug}`;

// Detect if body is markdown (has headings, bullets, or bold markers)
const isMarkdown = /^#{1,6} |^\*\*|^- |\*\*/m.test(post.body);
const bodyHtml = isMarkdown ? marked.parse(post.body) as string : null;

const articleLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.title,
  datePublished: post.publishedAt,
  dateModified: post.publishedAt,
  author: {
    "@type": "Person",
    name: post.author,
  },
  image: post.coverImage ? [post.coverImage] : [`${siteUrl}/images/og-default.svg`],
  description: post.excerpt,
  mainEntityOfPage: postUrl,
  publisher: {
    "@type": "Organization",
    name: "At Home Plans",
    logo: {
      "@type": "ImageObject",
      url: `${siteUrl}/images/og-default.svg`,
    },
  },
};

const formatLongDate = (dateValue: string): string =>
  new Date(dateValue).toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
  });
---

<BaseLayout
  title={post.title}
  description={post.excerpt}
  canonicalPath={`/blog/${post.slug}`}
  ogType="article"
  ogImage={post.coverImage || "/images/og-default.svg"}
>
  <div class="container sectionPad">
    <article class="postDetail">
      <p class="metaLine">{formatLongDate(post.publishedAt)} · {post.author}</p>
      <h1>{post.title}</h1>
      <p class="lead">{post.excerpt}</p>
      <div class="coverMedia detailCoverMedia">
        <img src={post.coverImage} alt={post.title} loading="eager" />
      </div>

      <div class="tagRow">
        {post.tags.map((tag) => (
          <span>{tag}</span>
        ))}
      </div>

      <div class="articleBody">
        {bodyHtml ? (
          <div class="markdownBody" set:html={bodyHtml} />
        ) : (
          post.body.split("\n\n").map((paragraph, index) => (
            <>
              <p>{paragraph}</p>
              {post.inlineImages?.filter((img) => img.afterParagraph === index + 1).map((img) => (
                <figure class="inlineImage">
                  <img src={img.src} alt={img.alt} loading="lazy" />
                  {img.caption && <figcaption>{img.caption}</figcaption>}
                </figure>
              ))}
            </>
          ))
        )}
      </div>

      <section class="sidebarBlock">
        <h2>Shop the Look on Etsy</h2>
        <ul>
          {post.etsyLinks.map((link) => (
            <li>
              <a href={link.url} target="_blank" rel="noreferrer">{link.label}</a>
            </li>
          ))}
        </ul>
      </section>

      {post.affiliateProducts && post.affiliateProducts.length > 0 && (
        <section class="shopThisLook">
          <div class="shopThisLookHeader">
            <h2>Products We Used</h2>
            <p class="affiliateDisclosureInline">
              This section contains affiliate links. We may earn a commission at no extra cost to you.
              <a href="/affiliate-disclosure">Learn more</a>.
            </p>
          </div>
          <ul class="affiliateProductList">
            {post.affiliateProducts.map((product) => (
              <li class="affiliateProductItem">
                <div class="affiliateProductInfo">
                  <span class="affiliateProductRetailer">{product.retailer}</span>
                  <strong class="affiliateProductName">{product.name}</strong>
                  <p class="affiliateProductDesc">{product.description}</p>
                  {product.priceRange && (
                    <span class="affiliateProductPrice">{product.priceRange}</span>
                  )}
                </div>
                <a
                  href={product.url}
                  target="_blank"
                  rel="sponsored nofollow noopener"
                  class="affiliateProductLink"
                >
                  Shop on {product.retailer} →
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      {post.pinterestPins && post.pinterestPins.length > 0 && (
        <PinterestSlider
          pins={post.pinterestPins}
          postUrl={postUrl}
          postTitle={post.title}
        />
      )}
    </article>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(articleLd)}></script>
  </div>
</BaseLayout>

<style>
  .markdownBody :global(h2) {
    font-size: 1.35rem;
    font-weight: 700;
    margin: 2rem 0 0.75rem;
    color: var(--color-text, #1a1a1a);
  }

  .markdownBody :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 1.5rem 0 0.5rem;
    color: var(--color-text, #1a1a1a);
  }

  .markdownBody :global(p) {
    margin: 0 0 1rem;
    line-height: 1.7;
  }

  .markdownBody :global(ul),
  .markdownBody :global(ol) {
    margin: 0.5rem 0 1rem 1.5rem;
    line-height: 1.7;
  }

  .markdownBody :global(li) {
    margin-bottom: 0.3rem;
  }

  .markdownBody :global(strong) {
    font-weight: 600;
  }

  .markdownBody :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border, #e5e0d8);
    margin: 2rem 0;
  }

  .markdownBody :global(a) {
    color: var(--color-accent, #8b6f5e);
    text-decoration: underline;
  }

  .markdownBody :global(blockquote) {
    border-left: 3px solid var(--color-border, #e5e0d8);
    margin: 1.5rem 0;
    padding: 0.5rem 1.25rem;
    color: var(--color-muted, #6b6560);
    font-style: italic;
  }

  .markdownBody :global(em) {
    font-style: italic;
    color: var(--color-muted, #6b6560);
  }

  .shopThisLook {
    margin-top: 2.5rem;
    padding: 2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  .shopThisLookHeader {
    margin-bottom: 1.5rem;
  }

  .shopThisLookHeader h2 {
    font-family: var(--font-sans);
    font-size: 1.15rem;
    font-weight: 600;
    margin: 0 0 0.4rem;
  }

  .affiliateDisclosureInline {
    font-size: 0.78rem;
    color: var(--subtle);
    margin: 0;
  }

  .affiliateDisclosureInline a {
    color: var(--muted);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .affiliateProductList {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .affiliateProductItem {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1.5rem;
    padding: 1.25rem;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 3px;
  }

  .affiliateProductInfo {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .affiliateProductRetailer {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--subtle);
  }

  .affiliateProductName {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
  }

  .affiliateProductDesc {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.6;
    margin: 0;
  }

  .affiliateProductPrice {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--text);
    margin-top: 0.15rem;
  }

  .affiliateProductLink {
    flex-shrink: 0;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 0.4rem 0.8rem;
    border-radius: 3px;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s, color 0.15s;
    align-self: center;
  }

  .affiliateProductLink:hover {
    background: var(--accent);
    color: #fff;
  }

  @media (max-width: 640px) {
    .affiliateProductItem {
      flex-direction: column;
    }

    .affiliateProductLink {
      align-self: flex-start;
    }
  }
</style>
